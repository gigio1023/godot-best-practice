{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Godot 3D World Layout",
  "type": "object",
  "required": ["version", "units", "landmarks"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "units": { "type": "string", "const": "meters" },
    "landmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "position", "size"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string" },
          "position": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "size": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "anchors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 3,
              "maxItems": 3
            }
          }
        }
      }
    }
  }
}
